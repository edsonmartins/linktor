# =============================================================================
# Linktor production environment
# Copy to /opt/linktor/.env on the VPS and chmod 600.
# Never commit the real .env file.
# =============================================================================

# --- Domain ------------------------------------------------------------------
ROOT_DOMAIN=linktor.dev
ACME_EMAIL=ops@linktor.dev

# --- Image tags (set per release; CI overrides these) ------------------------
BACKEND_IMAGE_TAG=latest
ADMIN_IMAGE_TAG=latest
LANDING_IMAGE_TAG=latest

# --- PostgreSQL --------------------------------------------------------------
POSTGRES_USER=linktor
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=linktor

# --- Redis -------------------------------------------------------------------
REDIS_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# --- JWT ---------------------------------------------------------------------
# Generate with: openssl rand -base64 64
JWT_SECRET=CHANGE_ME_LONG_RANDOM_BASE64

# --- MinIO (S3-compatible) ---------------------------------------------------
MINIO_ROOT_USER=linktor
MINIO_ROOT_PASSWORD=CHANGE_ME_STRONG_PASSWORD
MINIO_BUCKET=linktor-media

# --- Backups -----------------------------------------------------------------
# Used by deploy/scripts/backup.sh
BACKUP_DIR=/var/backups/linktor
BACKUP_RETENTION_DAYS=14
# Optional offsite target (S3 / MinIO / any S3-compatible endpoint).
# Leave BACKUP_S3_ENDPOINT empty to disable offsite push.
# Format: https://s3.example.com (bare scheme + host, no creds, no bucket).
# The backup script assembles the authenticated MC_HOST_<alias> URL from
# the four variables below; AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY are
# NOT honored by mc, so we set them explicitly via BACKUP_S3_* instead.
BACKUP_S3_ENDPOINT=
BACKUP_S3_BUCKET=
BACKUP_S3_ACCESS_KEY=
BACKUP_S3_SECRET_KEY=
